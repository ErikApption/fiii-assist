<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FiiiAssist.Controls.ImportWizardPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FiiiAssist.Converters"
    xmlns:firefly="using:FiiiAssist.FireflyIII"
    xmlns:models="using:FiiiAssist.Models"
    xmlns:vm="using:FiiiAssist.ViewModels">

    <UserControl.Resources>
        <converters:WizardStepToVisibilityConverter x:Key="StepToVisibility" />
        <converters:WizardStepNotClosedToVisibilityConverter x:Key="StepNotClosedToVisibility" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:IntToVisibilityConverter x:Key="IntToVisibility" />
        <converters:AmountToBrushConverter x:Key="AmountToBrush" />
        <converters:IntToZeroBoolConverter x:Key="IntToZeroBool" />
    </UserControl.Resources>

    <Border CornerRadius="8"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Visibility="{x:Bind ViewModel.CurrentStep, Converter={StaticResource StepNotClosedToVisibility}, Mode=OneWay}">

        <Grid>
            <!-- ── Header with title and close button ── -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Import QFX"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <Button Grid.Column="1"
                        Content="&#xE711;"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        Command="{x:Bind ViewModel.CloseCommand}"
                        ToolTipService.ToolTip="Close wizard"
                        Background="Transparent"
                        BorderThickness="0" />
            </Grid>

            <!-- ── Step content area ── -->
            <Grid Grid.Row="1">

                <!-- ════════════════════════════════════════════════════════════
                     Step 1: File Selection
                     ════════════════════════════════════════════════════════════ -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=FileSelection, Mode=OneWay}">
                    <TextBlock Text="Select a QFX/OFX file"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="Choose a file to import. The account will be auto-detected if possible."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <!-- Loading indicator (shown while parsing/loading accounts) -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                      Width="20" Height="20" />
                        <TextBlock Text="Processing file…"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- Error message -->
                    <InfoBar Severity="Error"
                             Title="Error"
                             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                             IsOpen="True"
                             IsClosable="False"
                             Visibility="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringToVisibility}, Mode=OneWay}" />
                </StackPanel>

                <!-- ════════════════════════════════════════════════════════════
                     Step 2: Account Selection (only if auto-match failed)
                     ════════════════════════════════════════════════════════════ -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=AccountSelection, Mode=OneWay}">

                    <TextBlock Text="Select an account"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <TextBlock Text="{x:Bind ViewModel.SelectedFileName, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <!-- Loading indicator -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                      Width="20" Height="20" />
                        <TextBlock Text="Loading accounts…"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- Error message with retry -->
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringToVisibility}, Mode=OneWay}">
                        <InfoBar Severity="Error"
                                 Title="Error"
                                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                 IsOpen="True"
                                 IsClosable="False" />
                        <Button Content="Retry"
                                Command="{x:Bind ViewModel.RetryLoadAccountsCommand}" />
                    </StackPanel>

                    <!-- Account list -->
                    <ListView ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedAccount, Mode=TwoWay}"
                              SelectionChanged="AccountListView_SelectionChanged"
                              SelectionMode="Single"
                              MaxHeight="200"
                              Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="firefly:AccountRead">
                                <TextBlock Text="{x:Bind Attributes.Name}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Back and Next buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Right">
                        <Button Content="Back"
                                Command="{x:Bind ViewModel.GoBackCommand}" />
                        <Button Content="Next"
                                Command="{x:Bind ViewModel.ProceedToTransactionPreviewCommand}"
                                IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <!-- ════════════════════════════════════════════════════════════
                     Step 2b: Account Update Confirmation
                     Shown when the QFX ACCTID doesn't match the selected account.
                     Asks user if Firefly III account should be updated.
                     ════════════════════════════════════════════════════════════ -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=AccountUpdateConfirmation, Mode=OneWay}">

                    <TextBlock Text="Update account number?"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <TextBlock TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="The QFX file contains account ID" />
                        <Run Text="{x:Bind ViewModel.QfxAccountId, Mode=OneWay}" FontWeight="SemiBold" />
                        <Run Text="but the selected account" />
                        <Run Text="{x:Bind ViewModel.SelectedAccountName, Mode=OneWay}" FontWeight="SemiBold" />
                        <Run Text="does not have a matching account number in Firefly III." />
                    </TextBlock>

                    <TextBlock Text="Would you like to update the Firefly III account with this number so future imports auto-match?"
                               TextWrapping="Wrap" />

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Back"
                                Command="{x:Bind ViewModel.GoBackCommand}" />
                        <Button Content="No, Skip"
                                Command="{x:Bind ViewModel.SkipAccountUpdateCommand}" />
                        <Button Content="Yes, Update"
                                Command="{x:Bind ViewModel.ConfirmAccountUpdateCommand}"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <!-- ════════════════════════════════════════════════════════════
                     Step 3: Transaction Preview
                     ════════════════════════════════════════════════════════════ -->
                <Grid Visibility="{x:Bind ViewModel.CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=TransactionPreview, Mode=OneWay}"
                      RowDefinitions="Auto,Auto,*,Auto">

                    <!-- Header: Account name and transaction count -->
                    <StackPanel Grid.Row="0" Spacing="4">
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}">
                            <Run Text="Importing to: " />
                            <Run Text="{x:Bind ViewModel.SelectedAccountName, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.TransactionCount, Mode=OneWay}" />
                            <Run Text=" transactions found" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Warning: No transactions found -->
                    <InfoBar Grid.Row="1"
                             IsOpen="{x:Bind ViewModel.IsTransactionListEmpty, Mode=OneWay}"
                             Severity="Warning"
                             Title="No transactions found in this file"
                             IsClosable="False"
                             Margin="0,8,0,0" />

                    <!-- Scrollable transaction list -->
                    <Border Grid.Row="2"
                            CornerRadius="4"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Margin="0,8,0,0">
                        <Grid RowDefinitions="Auto,*">
                            <!-- Column headers -->
                            <Grid Grid.Row="0" Padding="12,8" ColumnDefinitions="100,*,100"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                  CornerRadius="4,4,0,0">
                                <TextBlock Grid.Column="0" Text="Date" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Name" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Amount" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" />
                            </Grid>

                            <!-- Transaction rows -->
                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind ViewModel.Transactions, Mode=OneWay}"
                                      SelectionMode="None"
                                      MaxHeight="300">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FIIITransaction">
                                        <Grid Padding="12,6" ColumnDefinitions="100,*,100">
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Date}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind Amount}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{x:Bind Amount, Converter={StaticResource AmountToBrush}}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Action buttons: Back and Import -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Back"
                                Command="{x:Bind ViewModel.GoBackCommand}" />
                        <Button Content="Import"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.ConfirmImportCommand}"
                                IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <!-- ════════════════════════════════════════════════════════════
                     Step 4: Importing
                     Shows progress indicator with processed/total count.
                     Back and confirm buttons are not visible (CanGoBack/CanGoNext are false).
                     ════════════════════════════════════════════════════════════ -->
                <StackPanel Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=Importing, Mode=OneWay}">

                    <TextBlock Text="Importing Transactions"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               HorizontalAlignment="Center" />

                    <ProgressRing IsActive="True"
                                  Width="48" Height="48"
                                  HorizontalAlignment="Center" />

                    <TextBlock HorizontalAlignment="Center"
                               TextAlignment="Center">
                        <Run Text="Importing transactions... " />
                        <Run Text="{x:Bind ViewModel.ProcessedCount, Mode=OneWay}" />
                        <Run Text=" / " />
                        <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />
                    </TextBlock>

                    <!-- No back or confirm buttons during import (CanGoBack and CanGoNext are false) -->
                </StackPanel>

                <!-- ════════════════════════════════════════════════════════════
                     Step 5: Results
                     Shows success or partial failure summary.
                     Provides Close and Import Another buttons.
                     Back button is hidden (CanGoBack is false on Results step).
                     ════════════════════════════════════════════════════════════ -->
                <StackPanel Spacing="16"
                            Visibility="{x:Bind ViewModel.CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=Results, Mode=OneWay}">

                    <TextBlock Text="Import Complete"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <!-- Success message (shown when FailedCount == 0) -->
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.FailedCount, Converter={StaticResource IntToVisibility}, ConverterParameter=Invert, Mode=OneWay}">
                        <FontIcon Glyph="&#xE73E;" FontSize="32"
                                  Foreground="LimeGreen"
                                  HorizontalAlignment="Center" />
                        <TextBlock HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="16">
                            <Run Text="Successfully imported " />
                            <Run Text="{x:Bind ViewModel.ImportedCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" transactions" />
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind ViewModel.SkippedCount, Converter={StaticResource IntToVisibility}, Mode=OneWay}">
                            <Run Text="{x:Bind ViewModel.SkippedCount, Mode=OneWay}" />
                            <Run Text=" duplicate(s) skipped" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Partial failure message (shown when FailedCount > 0) -->
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.FailedCount, Converter={StaticResource IntToVisibility}, Mode=OneWay}">
                        <FontIcon Glyph="&#xE7BA;" FontSize="32"
                                  Foreground="Orange"
                                  HorizontalAlignment="Center" />
                        <TextBlock HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="16">
                            <Run Text="Imported " />
                            <Run Text="{x:Bind ViewModel.ImportedCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" of " />
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" transactions. " />
                            <Run Text="{x:Bind ViewModel.FailedCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" failed." />
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind ViewModel.SkippedCount, Converter={StaticResource IntToVisibility}, Mode=OneWay}">
                            <Run Text="{x:Bind ViewModel.SkippedCount, Mode=OneWay}" />
                            <Run Text=" duplicate(s) skipped" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Action buttons: Close and Import Another (no back button on Results) -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Button Content="Close"
                                Command="{x:Bind ViewModel.CloseCommand}" />
                        <Button Content="Import Another"
                                Command="{x:Bind ViewModel.ImportAnotherCommand}"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
