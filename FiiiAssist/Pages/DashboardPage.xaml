<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FiiiAssist.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FiiiAssist.Converters"
    xmlns:controls="using:FiiiAssist.Controls"
    xmlns:models="using:FiiiAssist.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility" />
        <converters:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
    </Page.Resources>

    <ScrollViewer Padding="24,16,24,16">
        <StackPanel Spacing="16">

            <!-- ── Title ─────────────────────────────────────────────────── -->
            <TextBlock Text="Dashboard" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- ── Status card ───────────────────────────────────────────── -->
            <Border CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="8">

                    <TextBlock Text="Status" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <Grid ColumnDefinitions="Auto,*">
                        <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="{x:Bind ViewModel.IsWatching,
                                        Converter={StaticResource BoolToStatusBrush}, Mode=OneWay}" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <TextBlock>
                        <Run Text="Watched folder: " FontWeight="SemiBold" />
                        <Run Text="{x:Bind ViewModel.WatchedFolder, Mode=OneWay}" />
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="▶  Start Watching"
                                Command="{x:Bind ViewModel.StartWatchingCommand}"
                                Visibility="{x:Bind ViewModel.IsWatching,
                                             Converter={StaticResource BoolToVisibility},
                                             ConverterParameter=Invert, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="⏹  Stop Watching"
                                Command="{x:Bind ViewModel.StopWatchingCommand}"
                                Visibility="{x:Bind ViewModel.IsWatching,
                                             Converter={StaticResource BoolToVisibility},
                                             Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Manual Import section ─────────────────────────────────── -->
            <Border CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Manual Import" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Import a QFX or OFX file directly into Firefly III."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button Content="📂  Import QFX"
                            Command="{x:Bind ViewModel.ImportWizard.OpenWizardCommand}"
                            IsEnabled="{x:Bind ViewModel.ImportWizard.CanOpenWizard, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Border>

            <!-- ── Import Wizard Panel ────────────────────────────────────── -->
            <controls:ImportWizardPanel />

            <!-- ── Import log ─────────────────────────────────────────────── -->
            <TextBlock Text="Import Log" Style="{StaticResource SubtitleTextBlockStyle}" />

            <Border CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" MinHeight="120"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <Grid>
                    <!-- Empty state -->
                    <TextBlock
                        Text="No imports yet. Start watching to begin."
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind ViewModel.LogEntries.Count,
                                     Converter={StaticResource BoolToVisibility},
                                     ConverterParameter=Invert, Mode=OneWay}" />

                    <ListView ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ImportLogEntry">
                                <Grid Padding="4,6" ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind TimestampText}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind FileName}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind StatusText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
