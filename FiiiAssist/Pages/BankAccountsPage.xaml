<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FiiiAssist.Pages.BankAccountsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FiiiAssist.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Grid Padding="24,16,24,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Bank Accounts" Style="{StaticResource TitleTextBlockStyle}" />

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Opacity="0.7"
                   Text="Your Firefly III asset accounts are listed below. Add a filename regex pattern to automatically match QFX files to the correct account during import." />

        <!-- Error message -->
        <InfoBar
            Grid.Row="2"
            Severity="Error"
            Title="Error"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
            IsClosable="False" />

        <!-- Toolbar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Content="Refresh"
                    Command="{x:Bind ViewModel.LoadAccountsCommand}" />
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Width="20" Height="20"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </StackPanel>

        <!-- Accounts table -->
        <ListView Grid.Row="4" ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
                  SelectionMode="None"
                  HorizontalAlignment="Stretch">
            <ListView.Header>
                <Grid Padding="12,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                      CornerRadius="4,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Account" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="Filename Pattern (Regex)" FontWeight="SemiBold" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:BankAccountRow">
                    <Grid Padding="12,6" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Account name (read-only, from API) -->
                        <TextBlock
                            Grid.Column="0"
                            Text="{x:Bind AccountName}"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis" />

                        <!-- Editable regex pattern -->
                        <TextBox
                            Grid.Column="1"
                            PlaceholderText="e.g. (?i)chequing|acct1234"
                            Text="{x:Bind FileNamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <TextBlock
            Grid.Row="4"
            Text="No accounts loaded. Click 'Refresh' to fetch accounts from Firefly III."
            Opacity="0.5"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Visibility="{x:Bind ViewModel.HasNoAccounts, Mode=OneWay}" />

    </Grid>
</Page>
