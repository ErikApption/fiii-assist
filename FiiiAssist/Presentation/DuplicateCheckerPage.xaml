<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FiiiAssist.Pages.DuplicateCheckerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FiiiAssist.Converters"
    xmlns:firefly="using:FiiiAssist.FireflyIII"
    xmlns:models="using:FiiiAssist.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:AmountToBrushConverter x:Key="AmountToBrush" />
    </Page.Resources>

    <Grid Padding="24,16,24,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Title ─────────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0" Text="Duplicate Checker"
                   Style="{StaticResource TitleTextBlockStyle}" />

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Opacity="0.7"
                   Text="Select an account to scan for potential duplicate transactions. Optionally filter by date range — leave dates unchecked to load all history. Transactions with the same amount on the same day are flagged." />

        <!-- ── Search criteria ────────────────────────────────────────── -->
        <Border Grid.Row="2" CornerRadius="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

            <StackPanel Spacing="12">
                <TextBlock Text="Search Criteria"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="8">
                    <!-- Start date -->
                    <CheckBox Grid.Row="0" Grid.Column="0"
                              Content="Start Date"
                              IsChecked="{x:Bind ViewModel.UseStartDate, Mode=TwoWay}" />
                    <DatePicker Grid.Row="1" Grid.Column="0"
                                Date="{x:Bind ViewModel.StartDate, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.UseStartDate, Mode=OneWay}" />

                    <!-- End date -->
                    <CheckBox Grid.Row="0" Grid.Column="1"
                              Content="End Date"
                              IsChecked="{x:Bind ViewModel.UseEndDate, Mode=TwoWay}" />
                    <DatePicker Grid.Row="1" Grid.Column="1"
                                Date="{x:Bind ViewModel.EndDate, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.UseEndDate, Mode=OneWay}" />

                    <!-- Account -->
                    <ComboBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                              Header="Account"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedAccount, Mode=TwoWay}"
                              PlaceholderText="Select an account…"
                              DisplayMemberPath="Attributes.Name" />
                </Grid>

                <!-- Loading accounts indicator -->
                <StackPanel Orientation="Horizontal" Spacing="8"
                            Visibility="{x:Bind ViewModel.IsLoadingAccounts, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingAccounts, Mode=OneWay}"
                                  Width="20" Height="20" />
                    <TextBlock Text="Loading accounts…"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Search button -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="🔍  Find Duplicates"
                            Command="{x:Bind ViewModel.SearchDuplicatesCommand}"
                            IsEnabled="{x:Bind ViewModel.CanSearch, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="20" Height="20"
                                  Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToVisibility}, Mode=OneWay}" />
                </StackPanel>

                <!-- Error message -->
                <InfoBar Severity="Error"
                         Title="Error"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         IsOpen="True"
                         IsClosable="False"
                         Visibility="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringToVisibility}, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <!-- ── Results summary and actions ─────────────────────────────── -->
        <Grid Grid.Row="3"
              Visibility="{x:Bind ViewModel.HasResults, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16"
                        VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Duplicate transactions: " FontWeight="SemiBold" />
                    <Run Text="{x:Bind ViewModel.TotalTransactionCount, Mode=OneWay}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="Selected for deletion: " />
                    <Run Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center"
                           Text="{x:Bind ViewModel.DeleteStatusMessage, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.DeleteStatusMessage, Converter={StaticResource StringToVisibility}, Mode=OneWay}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Select Duplicates"
                        Command="{x:Bind ViewModel.SelectDuplicatesCommand}" />
                <Button Content="🗑  Delete Selected"
                        Command="{x:Bind ViewModel.DeleteSelectedCommand}"
                        IsEnabled="{x:Bind ViewModel.CanDelete, Mode=OneWay}" />
                <ProgressRing IsActive="{x:Bind ViewModel.IsDeleting, Mode=OneWay}"
                              Width="20" Height="20"
                              Visibility="{x:Bind ViewModel.IsDeleting, Converter={StaticResource BoolToVisibility}, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- ── Transaction table ──────────────────────────────────────── -->
        <Border Grid.Row="4" CornerRadius="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Visibility="{x:Bind ViewModel.HasResults, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">

            <Grid RowDefinitions="Auto,*">
                <!-- Column headers -->
                <Grid Grid.Row="0" Padding="12,8"
                      ColumnDefinitions="40,30,90,*,120,120,100"
                      Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                      CornerRadius="4,4,0,0">
                    <TextBlock Grid.Column="0" Text="Sel" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="" FontWeight="SemiBold"
                               ToolTipService.ToolTip="Status: ✔ kept / ⚠ delete" />
                    <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="3" Text="Description" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="4" Text="Destination" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="5" Text="Type" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="6" Text="Amount" FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                </Grid>

                <!-- Transaction rows -->
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Transactions, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DuplicateTransactionRow">
                            <Grid Padding="12,6"
                                  ColumnDefinitions="40,30,90,*,120,120,100">
                                <!-- Selection checkbox -->
                                <CheckBox Grid.Column="0"
                                          IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                          MinWidth="0" Padding="0"
                                          VerticalAlignment="Center" />
                                <!-- Status indicator: ✔ kept / ⚠ duplicate -->
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE73E;"
                                              FontSize="14"
                                              Foreground="LimeGreen"
                                              Visibility="{x:Bind IsKept, Mode=OneWay}"
                                              ToolTipService.ToolTip="This transaction will be kept" />
                                    <TextBlock Text="⚠"
                                               Foreground="OrangeRed"
                                               FontWeight="Bold"
                                               Visibility="{x:Bind IsSelected, Mode=OneWay}"
                                               ToolTipService.ToolTip="Selected for deletion" />
                                </Grid>
                                <!-- Date -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind DateText}"
                                           VerticalAlignment="Center" />
                                <!-- Description -->
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind Description}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <!-- Destination -->
                                <TextBlock Grid.Column="4"
                                           Text="{x:Bind DestinationName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <!-- Type -->
                                <TextBlock Grid.Column="5"
                                           Text="{x:Bind TransactionType}"
                                           VerticalAlignment="Center" />
                                <!-- Amount -->
                                <TextBlock Grid.Column="6"
                                           Text="{x:Bind AmountText}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{x:Bind Amount, Converter={StaticResource AmountToBrush}}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ── Empty state (no results yet) ───────────────────────────── -->
        <TextBlock Grid.Row="4"
                   Text="Select criteria above and click 'Find Duplicates' to scan."
                   Opacity="0.5"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="{x:Bind ViewModel.HasResults, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert, Mode=OneWay}" />
    </Grid>
</Page>
