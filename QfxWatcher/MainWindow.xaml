<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="QfxWatcher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
    Title="QFX Watcher – Firefly III Import">

    <Grid>
        <NavigationView
            x:Name="NavView"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="DashboardNavItem"
                    Content="Dashboard"
                    Tag="Dashboard"
                    Icon="Home"
                    IsEnabled="{x:Bind SettingsVM.IsConnected, Mode=OneWay}" />
                <NavigationViewItem
                    Content="Bank Accounts"
                    Tag="BankAccounts"
                    Icon="ContactInfo"
                    IsEnabled="{x:Bind SettingsVM.IsConnected, Mode=OneWay}" />
                <NavigationViewItem
                    Content="Settings"
                    Tag="Settings"
                    Icon="Setting" />
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
