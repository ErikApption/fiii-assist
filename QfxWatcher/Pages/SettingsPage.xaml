<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QfxWatcher.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:QfxWatcher.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16,24,16">
        <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- ── Firefly III Server ─────────────────────────────────────── -->
            <Expander IsExpanded="True" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Firefly III Server"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                </Expander.Header>

                <StackPanel Spacing="12" Padding="0,8,0,4">

                    <TextBox
                        x:Name="ServerUrlBox"
                        Header="Server URL"
                        PlaceholderText="https://firefly.example.com"
                        Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextChanged="ServerUrlBox_TextChanged"
                        InputScope="Url" />

                    <PasswordBox
                        x:Name="TokenBox"
                        Header="Personal Access Token"
                        PlaceholderText="Enter your Firefly III Personal Access Token"
                        PasswordChanged="TokenBox_PasswordChanged" />

                    <ToggleSwitch
                        Header="Ignore SSL certificate validation"
                        IsOn="{x:Bind ViewModel.IgnoreSslCertificateValidation, Mode=TwoWay}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Test Connection"
                                Command="{x:Bind ViewModel.TestConnectionCommand}"
                                IsEnabled="{x:Bind ViewModel.CanTestConnection, Mode=OneWay}" />
                        <ProgressRing
                            IsActive="{x:Bind ViewModel.IsTestingConnection, Mode=OneWay}"
                            Width="20" Height="20"
                            Visibility="{x:Bind ViewModel.IsTestingConnection, Mode=OneWay}" />
                    </StackPanel>

                    <TextBlock
                        Text="{x:Bind ViewModel.TestConnectionMessage, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Visibility="{x:Bind ViewModel.HasTestConnectionMessage, Mode=OneWay}" />

                    <!-- Account list shown after successful connection test -->
                    <ComboBox
                        x:Name="DefaultAccountCombo"
                        Header="Default account for imports"
                        PlaceholderText="Select a default account (optional)"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
                        DisplayMemberPath="Name"
                        SelectedValuePath="Id"
                        SelectedValue="{x:Bind ViewModel.DefaultAccountId, Mode=TwoWay}"
                        Visibility="{x:Bind ViewModel.HasAccounts, Mode=OneWay}" />

                </StackPanel>
            </Expander>

            <!-- ── Watch Folder (disabled until connected) ────────────────── -->
            <Expander IsExpanded="True" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}">
                <Expander.Header>
                    <TextBlock Text="Watch Folder"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                </Expander.Header>

                <StackPanel Spacing="12" Padding="0,8,0,4">

                    <InfoBar
                        Severity="Informational"
                        Title="Auto-detected Edge downloads folder:"
                        Message="{x:Bind ViewModel.DetectedFolder, Mode=OneWay}"
                        IsOpen="True"
                        IsClosable="False" />

                    <TextBox
                        Header="Custom watch folder (leave blank to use auto-detected)"
                        PlaceholderText="e.g. C:\Users\You\Downloads"
                        Text="{x:Bind ViewModel.WatchFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Use Auto-Detected Folder"
                                Command="{x:Bind ViewModel.UseDetectedFolderCommand}" />
                        <Button Content="Clear"
                                Command="{x:Bind ViewModel.ClearWatchFolderCommand}" />
                    </StackPanel>

                </StackPanel>
            </Expander>

            <!-- ── Import Behaviour (disabled until connected) ─────────────── -->
            <Expander IsExpanded="True" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}">
                <Expander.Header>
                    <TextBlock Text="Import Behaviour"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                </Expander.Header>

                <StackPanel Spacing="12" Padding="0,8,0,4">

                    <ToggleSwitch
                        Header="Confirm before importing each file"
                        IsOn="{x:Bind ViewModel.ConfirmBeforeImport, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="Archive QFX file after successful import"
                        IsOn="{x:Bind ViewModel.ArchiveAfterImport, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="Skip duplicate transactions (by FitId)"
                        IsOn="{x:Bind ViewModel.SkipDuplicateTransactions, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="Skip duplicates by content (same date, amount, source and destination)"
                        IsOn="{x:Bind ViewModel.SkipDuplicatesByContent, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="Error if duplicate transaction detected"
                        IsOn="{x:Bind ViewModel.ErrorIfDuplicateHash, Mode=TwoWay}" />

                </StackPanel>
            </Expander>

            <!-- ── Info banner when not connected ─────────────────────────── -->
            <InfoBar
                Severity="Warning"
                Title="Connection required"
                Message="Test your Firefly III connection above to enable all features."
                IsOpen="{x:Bind ViewModel.IsNotConnected, Mode=OneWay}"
                IsClosable="False" />

        </StackPanel>
    </ScrollViewer>
</Page>
